{
  "patterns": {
    "IP": {
      "regex": "(?:[0-9]{1,3}\\.){3}[0-9]{1,3}",
      "description": "IPv4 address"
    },
    "IPV6": {
      "regex": "(?:[a-fA-F0-9]{1,4}:|:){1,7}(?:[a-fA-F0-9]{1,4}|:?)",
      "description": "IPv6 address"
    },
    "MAC": {
      "regex": "(?:[0-9a-fA-F]{2}(:|\\.|\\-)){5}([0-9a-fA-F]{2})|(?:[0-9a-fA-F]{4}(:|\\.|\\-)){2}([0-9a-fA-F]{4})",
      "description": "MAC address"
    },
    "DIGIT": {
      "regex": "\\d+",
      "description": "Numeric digits"
    },
    "PREFIX": {
      "regex": "(?:[0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}",
      "description": "IPv4 prefix with CIDR"
    },
    "PREFIXV6": {
      "regex": "(?:[a-fA-F0-9]{1,4}:|:){1,7}(?:[a-fA-F0-9]{1,4}|:?)/[0-9]{1,3}",
      "description": "IPv6 prefix with CIDR"
    },
    "WORD": {
      "regex": "\\S+",
      "description": "Single word (non-whitespace)"
    },
    "PHRASE": {
      "regex": "(\\S+ {1})+?\\S+",
      "description": "Multi-word phrase"
    },
    "ORPHRASE": {
      "regex": "\\S+|(\\S+ {1})+?\\S+",
      "description": "Optional phrase (single or multi-word)"
    },
    "ROW": {
      "regex": "(\\S+ +)+?\\S+",
      "description": "Table row"
    },
    "_line_": {
      "regex": ".+",
      "description": "Any line"
    }
  }
}
